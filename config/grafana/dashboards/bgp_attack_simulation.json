                "1": {
                  "color": "green",
                  "index": 0,
                  "text": "FLOWING (Success)"
                }
              },
              "type": "value"
            }
          ],
          "max": 16,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
